# Production Worker URL (no trailing slash). Example:
# VITE_VIEW_COUNTER_ENDPOINT=https://portfolio-view-counter.YOUR_SUBDOMAIN.workers.dev
VITE_VIEW_COUNTER_ENDPOINT=

# Ask Shirley API (same Worker host is fine). Example:
# VITE_ASK_SHIRLEY_ENDPOINT=https://portfolio-view-counter.YOUR_SUBDOMAIN.workers.dev
# If unset, the app falls back to VITE_VIEW_COUNTER_ENDPOINT, then a labeled local fallback.
VITE_ASK_SHIRLEY_ENDPOINT=

# Never set in production unless you intentionally want the authoring UI public.
# VITE_ASK_SHIRLEY_AUTHOR=true
VITE_ASK_SHIRLEY_AUTHOR=
